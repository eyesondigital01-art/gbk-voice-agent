# GBK Group Voice Agent - Environment Variables
# Copy this to .env and fill in your actual values

# Sarvam AI (STT + TTS)
SARVAM_API_KEY=your-sarvam-api-key-here

# OpenAI (LLM brain)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Public URL of this server (Railway/Render will give you this)
PUBLIC_URL=https://your-app-name.railway.app

# Make.com webhook URL for post-call data (Scenario 3)
MAKE_WEBHOOK_URL=https://hook.us1.make.com/your-post-call-webhook

# Vobiz credentials (for recording downloads)
VOBIZ_AUTH_ID=SA_CCRV76JF
VOBIZ_AUTH_TOKEN=a7805f9aae3624476572ac2f04d6c0d0511456db701b1c80324fd785226c0621

# Server port (Railway sets this automatically)
PORT=8000
